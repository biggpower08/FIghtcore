{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": {
      "ckpt_name": "PUT_PIXEL_ART_MODEL_NAME_HERE.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "{{PROMPT}}"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "inputs": {
      "clip": ["1", 1],
      "text": "{{NEGATIVE_PROMPT}}"
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "inputs": {
      "batch_size": 1,
      "height": "{{HEIGHT}}",
      "width": "{{WIDTH}}"
    }
  },
  "5": {
    "class_type": "KSampler",
    "inputs": {
      "cfg": 7,
      "denoise": 1,
      "latent_image": ["4", 0],
      "model": ["1", 0],
      "negative": ["3", 0],
      "positive": ["2", 0],
      "sampler_name": "euler",
      "scheduler": "normal",
      "seed": 0,
      "steps": 28
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "filename_prefix": "{{OUTPUT_PREFIX}}",
      "images": ["6", 0]
    }
  }
}
